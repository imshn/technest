{
    "python-envs.defaultEnvManager": "ms-python.python:pyenv",
    "files.watcherExclude": {
        "**/node_modules/**": true,
        "**/.next/**": true,
        "**/.turbo/**": true
    },
    "search.exclude": {
        "**/node_modules/**": true,
        "**/.next/**": true,
        "**/.turbo/**": true
    },
    "typescript.tsserver.watchOptions": {
        "excludeDirectories": [
            "**/node_modules",
            "**/.next",
            "**/.turbo"
        ]
    }
}
