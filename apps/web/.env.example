# ─────────────────────────────────────────────────────────────────────────────
# TechNest — Environment Variables
#
# ── Blog API + Admin Panel ────────────────────────────────────────────────────
# BLOG_API_KEY — used by OpenClaw (and any external agent) to authenticate write requests
#   Generate: openssl rand -hex 32
BLOG_API_KEY=your-blog-api-key-here

# ADMIN_PASSWORD — password for the /admin panel login screen
ADMIN_PASSWORD=your-admin-password-here

# ADMIN_SESSION_TOKEN — secret stored in the admin cookie after login
#   Generate separately: openssl rand -hex 32
ADMIN_SESSION_TOKEN=your-admin-session-token-here

# ── API Bridge ────────────────────────────────────────────────────────────────
# Base URL of the OpenClaw API bridge (no trailing slash)
# BLOG_API_KEY above is reused as the x-api-key header on every request
API_BASE_URL=https://imshn.cloud/api
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Analytics 4 ────────────────────────────────────────────────────────
# Format: G-XXXXXXXXXX
# Source: https://analytics.google.com → Admin → Data Streams → Web stream → Measurement ID
# NOTE: If GTM_ID is set, GA4 will be loaded *through* GTM — leave this blank to avoid double-counting.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Google Tag Manager ────────────────────────────────────────────────────────
# Format: GTM-XXXXXXX
# Source: https://tagmanager.google.com → your container → Container ID (top-right)
# Recommended: set this and manage GA4 + Ads inside GTM instead of directly here.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Google Ads Conversion Tracking ───────────────────────────────────────────
# Format: AW-XXXXXXXXX (the account-level ID, not a campaign ID)
# Source: Google Ads → Tools → Conversions → Set up → Tag setup → Global site tag
# Use with trackConversion('LABEL', value) helper in analytics.tsx
NEXT_PUBLIC_AW_ID=AW-XXXXXXXXX

# ── Google Search Console Domain Verification ────────────────────────────────
# The meta tag content value from Search Console → Add property → HTML tag method
# Source: https://search.google.com/search-console → Add property → Verify via HTML tag
# Example: AbCdEfGhIjKlMnOpQrStUvWx1234567890_abcde
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# ─────────────────────────────────────────────────────────────────────────────
# SETUP GUIDE — Google Search Console
# ─────────────────────────────────────────────────────────────────────────────
# 1. Go to https://search.google.com/search-console/welcome
# 2. Add property → URL prefix → https://technestsolutions.in
# 3. Choose "HTML tag" verification method
# 4. Copy the content="..." value into NEXT_PUBLIC_GOOGLE_VERIFICATION above
# 5. Deploy, then click Verify in Search Console
# 6. Submit sitemap: https://technestsolutions.in/sitemap.xml
#
# ─────────────────────────────────────────────────────────────────────────────
# SETUP GUIDE — Google Analytics 4
# ─────────────────────────────────────────────────────────────────────────────
# 1. Go to https://analytics.google.com → Admin → Create Account / Property
# 2. Platform: Web → enter https://technestsolutions.in
# 3. Copy Measurement ID (G-XXXXXXXXXX) into NEXT_PUBLIC_GA_ID
# 4. In GA4: Admin → Custom Definitions → add custom event "cta_click" dimension
# 5. Goals: Admin → Conversions → mark "cta_click" and "calendly_booked" as conversions
#
# ─────────────────────────────────────────────────────────────────────────────
# SETUP GUIDE — Google Tag Manager
# ─────────────────────────────────────────────────────────────────────────────
# 1. Go to https://tagmanager.google.com → Create Account
# 2. Container type: Web → copy GTM-XXXXXXX into NEXT_PUBLIC_GTM_ID
# 3. In GTM: create a GA4 Configuration tag with your Measurement ID
# 4. Add Google Ads Conversion Linker tag
# 5. Publish the container
# 6. Unset NEXT_PUBLIC_GA_ID (GTM will fire GA4 — no need for both)
#
# ─────────────────────────────────────────────────────────────────────────────
# SETUP GUIDE — Google Ads + Keyword Planner
# ─────────────────────────────────────────────────────────────────────────────
# 1. Go to https://ads.google.com → Create account
# 2. Tools → Keyword Planner → "Discover new keywords" using:
#    Seed terms: "AI automation agency", "n8n workflow automation", "multi agent AI",
#                "agentic workflow development", "SaaS development company"
# 3. Filter: Monthly searches > 100, Competition: Low/Medium
# 4. Export top 30 keywords → add to blog posts and service pages
# 5. Tools → Conversions → + New conversion → Website → name "Calendly Booking"
# 6. Copy Conversion ID (AW-XXXXXXXXX) → NEXT_PUBLIC_AW_ID
# 7. Copy Conversion Label → use in trackConversion('LABEL') on booking confirmation
#
# ─────────────────────────────────────────────────────────────────────────────
# SETUP GUIDE — Vercel Analytics
# ─────────────────────────────────────────────────────────────────────────────
# No env var needed — Vercel Analytics is enabled via the @vercel/analytics package.
# To activate: Vercel dashboard → your project → Analytics tab → Enable
# Speed Insights: Vercel dashboard → your project → Speed Insights tab → Enable
#
# ─────────────────────────────────────────────────────────────────────────────
# QUICK KEYWORD TARGETS (add to service page copy + blog meta descriptions)
# ─────────────────────────────────────────────────────────────────────────────
# High intent (bottom-funnel):
#   "hire AI automation agency", "custom n8n automation development",
#   "agentic workflow development company", "multi agent AI system development"
# Mid-funnel:
#   "n8n vs zapier comparison", "AI automation ROI statistics",
#   "how to build multi agent AI system", "SaaS MVP development cost"
# Brand defense:
#   "TechNest AI agency", "technestsolutions.in"
