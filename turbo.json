{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "API_BASE_URL",
        "BLOG_API_KEY",
        "ADMIN_PASSWORD",
        "ADMIN_SESSION_TOKEN",
        "NEXT_PUBLIC_GA_ID",
        "NEXT_PUBLIC_GTM_ID",
        "NEXT_PUBLIC_GOOGLE_VERIFICATION",
        "OPENCLAW_WEBHOOK_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
